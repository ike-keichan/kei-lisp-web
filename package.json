{
  "name": "kei-lisp-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Web REPL for kei-lisp",
  "author": "Keisuke Ikeda",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "kei-lisp": "^2.3.0",
    "kei-lisp-plugin-graphics": "^1.0.1",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^17.6.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vue-tsc": "^3.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.30.3"
}
